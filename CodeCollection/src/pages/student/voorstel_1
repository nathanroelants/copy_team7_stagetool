
<!DOCTYPE html>
<html lang="nl-BE">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stage.be - Stagevoorstel Nathan Roelants</title>
    <!-- Use the common CSS structure -->
    <link rel="stylesheet" href="../css/global.css">
    <!-- Link to the specific styles for this page -->
    <link rel="stylesheet" href="../css/stage.css">
</head>
<body>

    <!-- Main Container to divide Sidebar and Content -->
    <div class="page-container">
        
        <!-- Left Sidebar (STAGE.BE) with special highlight -->
        <aside class="sidebar current-page-highlight">
            <div class="logo-box">STAGE.BE</div>
            <nav class="sidebar-nav">
                <button class="nav-button current">Stagevoorstel</button>
            </nav>
            <button class="logout-button">Uitloggen</button>
        </aside>

        <!-- Main Content Area -->
        <main class="content-area">
            
            <!-- Content Header -->
            <header class="content-header">
                <div class="user-display">Nathan Roelants</div>
            </header>

            <!-- Main Form Card -->
            <section class="form-card">
                
                <!-- Section 1: Company Data -->
                <fieldset>
                    <legend>Gegevens bedrijf</legend>
                    <div class="grid-2-col">
                        <div class="form-group">
                            <input type="text" value="Cronos Group NV" readonly>
                            <label>Bedrijfsnaam</label>
                        </div>
                        <div class="form-group">
                            <input type="text" value="Thomas Peeters" readonly>
                            <label>Naam stagementor</label>
                        </div>
                        <div class="form-group">
                            <input type="email" value="t.peeters@cronos.be" readonly>
                            <label>E-mail stagementor</label>
                        </div>
                        <div class="form-group">
                            <input type="text" value="Lena Vermeersch" readonly>
                            <label>Naam begeleidende docent</label>
                        </div>
                    </div>
                </fieldset>

                <hr>

                <!-- Section 2: Assigned Teacher -->
                <fieldset>
                    <legend>Toegekende docent</legend>
                    <div class="grid-2-col">
                        <div class="form-group">
                            <input type="text" value="Lena Vermeersch" readonly>
                            <label>Naam docent</label>
                        </div>
                        <div class="form-group">
                            <input type="email" value="l.vermeersch@ehb.be" readonly>
                            <label>E-mail docent</label>
                        </div>
                    </div>
                </fieldset>

                <hr>

                <!-- Section 3: Internship Period -->
                <fieldset>
                    <legend>Stageperiode</legend>
                    <div class="grid-2-col">
                        <div class="form-group">
                            <input type="text" value="02/02/2026" readonly>
                            <label>Startdatum</label>
                        </div>
                        <div class="form-group">
                            <input type="text" value="29/05/2026" readonly>
                            <label>Einddatum</label>
                        </div>
                    </div>
                </fieldset>

                <hr>

                <!-- Section 4: Internship Assignment -->
                <fieldset>
                    <legend>Stageopdracht</legend>
                    <div class="form-group">
                        <textarea readonly rows="4">Ik zal meewerken aan de ontwikkeling van een intern webplatform voor projectbeheer. De focus ligt op frontend development in React en integratie met bestaande REST API's van Cronos Group.</textarea>
                        <label>Omschrijving stageopdracht</label>
                    </div>
                </fieldset>

                <hr>

                <!-- Section 5: Competencies -->
                <fieldset>
                    <legend>Competenties</legend>
                    <div class="grid-2-col">
                        <div class="form-group">
                            <input type="text" value="React, JavaScript" readonly>
                            <label>Technische skills</label>
                        </div>
                        <div class="form-group">
                            <input type="text" value="REST API, Git" readonly>
                            <label>Tools</label>
                        </div>
                    </div>
                </fieldset>

                <hr>

                <!-- Section 6: Work Address -->
                <fieldset>
                    <legend>Werkadres</legend>
                    <div class="grid-2-col">
                        <div class="form-group">
                            <input type="text" value="Luchthavenlei 1" readonly>
                            <label>Straat</label>
                        </div>
                        <div class="form-group">
                            <input type="text" value="2100 Antwerpen" readonly>
                            <label>Gemeente</label>
                        </div>
                    </div>
                </fieldset>
                
                <hr>

                <!-- Final Action Buttons -->
                <div class="action-buttons">
                    <button class="btn-cancel">Annuleren</button>
                    <button class="btn-submit">Indienen</button>
                </div>

            </section>
        </main>
    </div>

</body>
</html>